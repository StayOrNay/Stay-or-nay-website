# Copy this file to .env (for local dev) and fill in your own Supabase
# project's values — find them in the Supabase dashboard under
# Project Settings → API.
#
# For the live site, set these same two variables in Cloudflare Pages:
# Workers & Pages → stayornay → Settings → Environment variables (Production).
# They get baked into the JS bundle at build time, so a Cloudflare rebuild is
# needed after adding/changing them.
#
# The anon key is a public, client-safe key — Supabase is designed to have it
# shipped in frontend code (it's restricted by your project's Row Level
# Security rules, not by secrecy). Never put the "service_role" key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
